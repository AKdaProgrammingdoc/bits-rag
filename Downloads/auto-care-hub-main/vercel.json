{
  "version": 2,
  "buildCommand": "npm run build",
  "framework": null,
  "outputDirectory": "dist/client",
  "functions": {
    "api/server.js": {
      "runtime": "nodejs20.x",
      "includeFiles": "api/ssr.mjs"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/server"
    }
  ]
}
